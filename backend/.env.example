APP_NAME=TruthLens API
APP_VERSION=1.0.0
DEBUG=true

DATABASE_URL=postgresql://truthlens:truthlens@localhost:5432/truthlens
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60

MODEL_PATH=models/weights
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000","chrome-extension://*"]

# Hugging Face Inference API (optional, for cloud/deep analysis AI model)
# Get a free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=
